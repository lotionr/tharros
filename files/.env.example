# Copy this to .env.local and fill in real values
# NEVER commit .env.local to git

# fal — generative media platform
# https://fal.ai/dashboard → API Keys
# NOTE: NO NEXT_PUBLIC prefix — this is server-side only
# All fal calls go through /api/fal-proxy to keep this key off the browser
FAL_KEY=

# Overshoot — real-time vision API (free in beta)
# https://overshoot.ai/
NEXT_PUBLIC_OVERSHOOT_API_KEY=

# ElevenLabs — voice generation
# https://elevenlabs.io/ → Profile → API Keys
NEXT_PUBLIC_ELEVENLABS_API_KEY=

# ElevenLabs Voice ID — use Flash v2.5 for lowest latency
# https://elevenlabs.io/voice-lab — copy Voice ID of chosen voice
NEXT_PUBLIC_ELEVENLABS_VOICE_ID=

# Mux — video infrastructure
# https://dashboard.mux.com/ → Settings → API Access Tokens
# NOTE: NO NEXT_PUBLIC prefix — server-side only (used in /api/mux-upload, /api/mux-asset)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Mux Environment Key — public, used by mux-player-react in the browser
# https://dashboard.mux.com/ → Environments → your env → Data key
NEXT_PUBLIC_MUX_ENV_KEY=
